@startuml
title Sistema de Gestión de Pedidos - Diagrama de Clases

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

enum EstadoPedido {
  ACTIVO
  CANCELADO
  COMPLETADO
}

enum EstadoCarrito {
  ACTIVO
  CANCELADO
  COMPLETADO
}

enum Rol {
  ADMINISTRADOR
  CLIENTE
}

class Empresa {
  - id: short
  - codigo: string
  - nombre: string
  - descripcion: string
  - correo: string
  - direccion: string
  - ciudad: string
  - pais: string
  - urlLogo: string
  - plantilla: string
  - usarPlantilla: bool
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class Usuario {
  - id: int
  - empresaId: short
  - codigo: string
  - rol: Rol
  - correo: string
  - contrasena: string
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class Cliente {
  - id: int
  - usuarioId: int
  - empresaId: short
  - codigo: string
  - cedula: string
  - nombres: string
  - apellidos: string
  - telefono: string
  - direccion: string
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class Categoria {
  - id: int
  - categoriaPadreId: int?
  - empresaId: short
  - codigo: string
  - nombre: string
  - descripcion: string
  - urlImagen: string
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class Producto {
  - id: int
  - empresaId: short
  - categoriaId: int
  - codigo: string
  - marca: string
  - nombre: string
  - descripcion: string
  - impuesto: decimal
  - descuento: decimal
  - precio: decimal
  - stock: int
  - urlImagen: string
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class MetodoPago {
  - id: short
  - empresaId: short
  - codigo: string
  - nombre: string
  - descripcion: string
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class CarritoCompras {
  - id: int
  - empresaId: short
  - clienteId: int
  - codigo: string
  - datos: JsonDocument
  - estado: EstadoCarrito
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class Pedido {
  - id: int
  - empresaId: short
  - clienteId: int
  - metodoPagoId: short
  - estado: EstadoPedido
  - fechaPedido: DateTime
  - total: decimal
  - subtotal: decimal
  - impuesto: decimal
  - descuento: decimal
  - direccionEntrega: string
  - notas: string
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

class DetallePedido {
  - id: int
  - pedidoId: int
  - productoId: int
  - cantidad: int
  - precioUnitario: decimal
  - total: decimal
  - subtotal: decimal
  - impuesto: decimal
  - descuento: decimal
  - activo: bool
  - fechaCreacion: DateTime
  - fechaActualizacion: DateTime
}

Empresa "1" -- "0..*" Usuario
Empresa "1" -- "0..*" Cliente
Empresa "1" -- "0..*" Categoria
Empresa "1" -- "0..*" Producto
Empresa "1" -- "0..*" MetodoPago
Empresa "1" -- "0..*" CarritoCompras
Empresa "1" -- "0..*" Pedido

Usuario "1" -- "0..1" Cliente

Categoria "0..1" -- "0..*" Categoria : padre / subcategorías
Categoria "1" -- "0..*" Producto

Cliente "1" -- "0..*" CarritoCompras
Cliente "1" -- "0..*" Pedido

MetodoPago "1" -- "0..*" Pedido

Pedido "1" *-- "1..*" DetallePedido
Producto "1" -- "0..*" DetallePedido

Usuario ..> Rol : utiliza
CarritoCompras ..> EstadoCarrito : utiliza
Pedido ..> EstadoPedido : utiliza

@enduml