@startuml
title Sistema de Gestión de Pedidos - Diagrama de Casos de Uso

left to right direction

actor Administrador
actor Cliente

rectangle "Sistema de Gestión de Pedidos" {

  usecase "Iniciar sesión" as UC_IniciarSesion
  usecase "Crear categoría" as UC_CrearCategoria
  usecase "Crear producto" as UC_CrearProducto
  usecase "Ver productos" as UC_VerProductos
  usecase "Buscar productos" as UC_BuscarProductos
  usecase "Realizar pedido" as UC_RealizarPedido
  usecase "Ver historial de pedidos" as UC_HistorialPedidos
}

Administrador --> UC_IniciarSesion
Administrador --> UC_CrearCategoria
Administrador --> UC_CrearProducto
Administrador --> UC_HistorialPedidos

Cliente --> UC_IniciarSesion
Cliente --> UC_VerProductos
Cliente --> UC_BuscarProductos
Cliente --> UC_RealizarPedido
Cliente --> UC_HistorialPedidos

UC_RealizarPedido .> UC_IniciarSesion : <<include>>
UC_BuscarProductos .> UC_VerProductos : <<extend>>

@enduml